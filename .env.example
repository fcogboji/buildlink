# Copy to `.env.local` and fill in real values:
#   cp .env.example .env.local
#
# Next.js loads: `.env.local` (and `.env`) — never commit real secrets.

# App URL (used in Stripe redirects, emails later)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: comma-separated emails that receive ADMIN in the database (fallback if not set in Clerk)
ADMIN_EMAILS=you@example.com

# Neon Postgres — https://neon.tech
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------------------
# Stripe — https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
# Server-only (never expose to the browser)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Publishable (safe for the browser). Required if you use Stripe.js, Payment Element,
# or any client-side Stripe APIs. Checkout Sessions created only on the server can
# work with just STRIPE_SECRET_KEY, but keep this set for future embedded UI.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_51RGHm7I2EoCzCxLN3yXnc5Y9POcKTq3Lt0UevvwTMbSB4zmrmIJcxNsVrB56K6jzXxi25XTq4NnBMAA9tZzPZxdC00eNy5pQpy